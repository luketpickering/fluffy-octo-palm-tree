loc=$(pwd)
cd /usr/local/t2k/current/nd280SoftwarePilot/
.  nd280SoftwarePilot.profile &> /dev/null
set -x
cd /usr/local/t2k/current/nd280SoftwareMaster_*/Linux-*/
set +x
. setup.sh &> /dev/null
if [ -e $NEUTROOT/$NEUTCONFIG/bin/setup.NEUT.sh ]; then
  . $NEUTROOT/$NEUTCONFIG/bin/setup.NEUT.sh
fi
if [ -e $NEUTGEOMROOT/$NEUTGEOMCONFIG/bin/setup.NEUTGeom.sh ]; then
  . $NEUTGEOMROOT/$NEUTGEOMCONFIG/bin/setup.NEUTGeom.sh
fi
cd $loc
unset loc
