#!/bin/bash

#source /work4/ppd/picker24/nd280/scripts/batch/utils/deploy-A25-tensors

export NEUT_CRSPATH=/work4/ppd/picker24/nd280/inputs/crsdat

POT=${1}
BEAM_POWER=620
CYCLE_TIME=1.52

/work4/ppd/picker24/nd280/scripts/batch/stubs/numc \
        /work4/ppd/picker24/nd280/inputs/neut_cards/NIWG_A25-lowmem.toml \
        Magnet magnet \
        /work4/ppd/picker24/nd280/inputs/fluxes/ND6.250kA.all.root \
        /work4/ppd/picker24/nd280/inputs/maxint/ND6.250kA.all-A25-magnet.maxint.root \
        ${POT}

NUMC_FILE=$(/work4/ppd/picker24/nd280/scripts/batch/utils/findnumc)

/work4/ppd/picker24/nd280/scripts/batch/stubs/sim2evana \
	/work4/ppd/picker24/nd280/inputs/neut_cards/NIWG_A25-lowmem.toml \
	${NUMC_FILE} \
	/work4/ppd/picker24/nd280/inputs/maxint/ND6.250kA.all-A25-magnet.maxint.root \
	${BEAM_POWER} ${CYCLE_TIME}
