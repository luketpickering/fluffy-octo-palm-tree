#!/bin/bash

#SBATCH -p scarf
#SBATCH -n 1
#SBATCH -o %J.log
#SBATCH -J nd280job

if [ -z "${SLURM_JOB_ACCOUNT}" ]; then
	SLURM_JOB_ACCOUNT=ppd
	SLURM_JOB_NAME=test
	SLURM_JOB_ID=22072207
	SLURM_LOCALID=123
fi

export SUBDIR=$(pwd)

if [ -e /scratch ]; then
  export JOBDIR=/scratch/picker24/${SLURM_JOB_ACCOUNT}_${SLURM_JOB_NAME}_${SLURM_JOB_ID}
else
  export JOBDIR=/tmp/${SLURM_JOB_ACCOUNT}_${SLURM_JOB_NAME}_${SLURM_JOB_ID}
fi

SECONDS=0
echo "Job start: $(date)"

set -x
mkdir -p ${JOBDIR}
set +x

JOB_SCRIPT=$(readlink -f ${1})
shift;

srun -o "%j.%t.log"  time $MYWORK4/nd280/scripts/env/apptainer.run ${JOB_SCRIPT} ${@}

set -x
ls ${JOBDIR}/*
rm -r ${JOBDIR}
echo "Job end: $(date)"
echo "Job elapsed: ${SECONDS}s"
